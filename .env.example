# Database
DATABASE_URL=postgresql+asyncpg://microdify:microdify@pg:5432/microdify

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-me-to-a-random-secret

# LLM Provider: openai | anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# API Keys
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Embedding
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL defaults (used by docker-compose.yml)
POSTGRES_USER=microdify
POSTGRES_PASSWORD=microdify
POSTGRES_DB=microdify
